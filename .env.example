# Purchase System — Environment Variable Template
# https://github.com/CBaney-IG/PurchaseSystem
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# Production secrets are managed in the Vercel dashboard.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Local dev: get from `supabase start` output
# Staging/Prod: get from Supabase Dashboard > Settings > API Keys

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Service role key — SERVER ONLY. Never expose to the browser.
# This key bypasses Row Level Security. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ── Azure AD SSO ──────────────────────────────────────────────────────────────
# Get from IT Director — Azure Portal > App Registrations > USMP Development
# Redirect URI to register: https://localhost:3003/auth/callback

AZURE_AD_TENANT_ID=your-tenant-id-here
AZURE_AD_CLIENT_ID=your-client-id-here
AZURE_AD_CLIENT_SECRET=your-client-secret-here

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get API key from resend.com — free tier is sufficient for dev

# Use re_stub_xxxxx (any re_stub prefix) to run in stub mode — emails are logged to console,
# not sent. Replace with a real key from resend.com when ready to send live email.
RESEND_API_KEY=re_stub_replace_with_real_key_when_available
RESEND_FROM_EMAIL=noreply@bpogroup.co.za

# ── Email action token signing ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used to sign HMAC-SHA256 JWT tokens embedded in approval email links.
# Must be at least 32 characters. Rotate if compromised.

EMAIL_ACTION_SECRET=replace-with-64-char-random-string-never-commit-real-value

# ── Snowflake integration ─────────────────────────────────────────────────────
# SNOWFLAKE_WEBHOOK_SECRET: shared secret validated in x-webhook-secret header.
#   Generate with: openssl rand -hex 32
# SNOWFLAKE_ENDPOINT_URL: REST pipeline endpoint — get from Data team.

SNOWFLAKE_WEBHOOK_SECRET=replace-with-64-char-random-string

# Use "STUB://local-dev" to run in stub mode — payloads are logged to console,
# not sent to Snowflake. Replace with the real endpoint URL from the Data team
# when the Snowflake pipeline is ready.
SNOWFLAKE_ENDPOINT_URL=STUB://local-dev

# Optional: Bearer token for USMP → Snowflake HTTP auth (provided by Data team)
SNOWFLAKE_BEARER_TOKEN=

# ── App URL ───────────────────────────────────────────────────────────────────
# Must match the environment exactly — used in email links and OAuth redirects.
# Local dev:  https://localhost:3003
# Preview:    set automatically by Vercel (override per-deployment)
# Production: https://your-production-domain.com

NEXT_PUBLIC_APP_URL=https://localhost:3003
